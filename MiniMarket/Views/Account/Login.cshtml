@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - MiniMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .login-card {
            animation: fadeInUp 0.6s ease-out;
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.95);
        }
        
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .input-group-text {
            background-color: transparent;
            border-right: none;
        }
        
        .form-control {
            border-left: none;
        }
        
        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }
        
        .btn-login {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            transition: all 0.3s ease;
        }
        
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }
        
        .icon-circle {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: 0 auto;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center vh-100">
    
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                
                <!-- Tarjeta de login -->
                <div class="card shadow-lg border-0 rounded-4 overflow-hidden login-card">
                    
                    <!-- Header con icono -->
                    <div class="text-center pt-4">
                        <div class="icon-circle mx-auto mb-3">
                            <i class="bi bi-shop fs-1 text-white"></i>
                        </div>
                        <h2 class="fw-bold" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                            MiniMarket
                        </h2>
                        <p class="text-muted small">Sistema de Punto de Venta</p>
                    </div>
                    
                    <!-- Formulario -->
                    <div class="card-body p-4 pt-0">
                        
                        <!-- Mensaje de error -->
                        <div id="errorMessage" style="display: none;" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <span id="errorText"></span>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        
                        <form id="loginForm">
                            
                            <!-- Campo Usuario -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="bi bi-person"></i> Usuario
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 rounded-3 rounded-end-0">
                                        <i class="bi bi-person-circle text-secondary"></i>
                                    </span>
                                    <input type="text" id="usuario" name="usuario" class="form-control border-start-0 rounded-3 rounded-start-0" 
                                           placeholder="Ingresa tu usuario" required autofocus />
                                </div>
                                <div class="form-text">Usuario de prueba: admin, vendedor, gerente</div>
                            </div>
                            
                            <!-- Campo Contraseña -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="bi bi-lock"></i> Contraseña
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 rounded-3 rounded-end-0">
                                        <i class="bi bi-key text-secondary"></i>
                                    </span>
                                    <input type="password" id="password" name="password" class="form-control border-start-0 rounded-3 rounded-start-0" 
                                           placeholder="Ingresa tu contraseña" required />
                                    <button type="button" class="btn btn-outline-secondary rounded-3 rounded-start-0" 
                                            onclick="togglePassword()" style="border-left: none;">
                                        <i class="bi bi-eye" id="toggleIcon"></i>
                                    </button>
                                </div>
                                <div class="form-text">Contraseña: admin123 / vender123 / gerente123</div>
                            </div>
                            
                            <!-- Checkbox Recordar -->
                            <div class="mb-4 form-check">
                                <input type="checkbox" class="form-check-input" id="rememberMe">
                                <label class="form-check-label text-muted" for="rememberMe">
                                    <i class="bi bi-check2-square"></i> Recordarme
                                </label>
                            </div>
                            
                            <!-- Botón Ingresar -->
                            <button type="submit" class="btn btn-login text-white w-100 py-2 rounded-3 shadow-sm mb-3">
                                <i class="bi bi-box-arrow-in-right"></i> Ingresar al Sistema
                            </button>
                            
                            <!-- Enlaces adicionales -->
                            <div class="text-center">
                                <a href="#" class="text-decoration-none small text-muted" data-bs-toggle="modal" data-bs-target="#modalAyuda">
                                    <i class="bi bi-question-circle"></i> ¿Olvidaste tu contraseña?
                                </a>
                                <br>
                                <small class="text-muted">
                                    <i class="bi bi-shield-check"></i> Acceso seguro
                                </small>
                            </div>
                        </form>
                    </div>
                </div>
                
                <!-- Footer -->
                <div class="text-center mt-4">
                    <small class="text-white-50">
                        <i class="bi bi-c-circle"></i> 2024 MiniMarket - Todos los derechos reservados
                    </small>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Modal de Ayuda -->
    <div class="modal fade" id="modalAyuda" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-question-circle text-primary"></i> Recuperar contraseña
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Para recuperar tu contraseña, contacta al administrador del sistema:</p>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-envelope"></i> Email: admin@minimarket.com</li>
                        <li><i class="bi bi-telephone"></i> Teléfono: (55) 1234-5678</li>
                    </ul>
                    <hr>
                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle"></i> Credenciales de prueba:<br>
                        <strong>Admin:</strong> admin / admin123 → Dashboard completo<br>
                        <strong>Vendedor:</strong> vendedor / vender123 → Pantalla de ventas<br>
                        <strong>Gerente:</strong> gerente / gerente123 → Reportes y productos
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-primary rounded-pill" data-bs-dismiss="modal">Entendido</button>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Credenciales con roles y redirecciones
        const usuariosValidos = [
            { 
                usuario: "admin", 
                password: "admin123", 
                rol: "admin",
                controller: "Home",
                action: "Index"
            },
            { 
                usuario: "vendedor", 
                password: "vender123", 
                rol: "vendedor",
                controller: "Venta",
                action: "create"
            },
            { 
                usuario: "gerente", 
                password: "gerente123", 
                rol: "gerente",
                controller: "Producto",
                action: "Index"
            }
        ];
        
        // Función para mostrar/ocultar contraseña
        function togglePassword() {
            var passwordInput = document.getElementById('password');
            var toggleIcon = document.getElementById('toggleIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('bi-eye');
                toggleIcon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('bi-eye-slash');
                toggleIcon.classList.add('bi-eye');
            }
        }
        
        // Función para mostrar error
        function mostrarError(mensaje) {
            var errorDiv = document.getElementById('errorMessage');
            var errorText = document.getElementById('errorText');
            errorText.innerText = mensaje;
            errorDiv.style.display = 'block';
            
            // Auto ocultar después de 3 segundos
            setTimeout(function() {
                errorDiv.style.display = 'none';
            }, 3000);
        }
        
        // Función para guardar sesión local
        function guardarSesion(usuario, rol) {
            const sessionData = {
                usuario: usuario,
                rol: rol,
                fecha: new Date().toISOString()
            };
            sessionStorage.setItem('usuarioActual', JSON.stringify(sessionData));
            localStorage.setItem('usuarioActual', JSON.stringify(sessionData));
        }
        
        // Función para recordar usuario
        function recordarUsuario(usuario) {
            if (document.getElementById('rememberMe').checked) {
                localStorage.setItem('usuarioRecordado', usuario);
            } else {
                localStorage.removeItem('usuarioRecordado');
            }
        }
        
        // Función para cargar usuario recordado
        function cargarUsuarioRecordado() {
            var usuarioRecordado = localStorage.getItem('usuarioRecordado');
            if (usuarioRecordado) {
                document.getElementById('usuario').value = usuarioRecordado;
                document.getElementById('rememberMe').checked = true;
            }
        }
        
        // Validar login y obtener redirección
        function validarLogin(usuario, password) {
            // Buscar si las credenciales existen
            var usuarioValido = usuariosValidos.find(u => u.usuario === usuario && u.password === password);
            
            if (usuarioValido) {
                return {
                    success: true,
                    rol: usuarioValido.rol,
                    controller: usuarioValido.controller,
                    action: usuarioValido.action,
                    usuario: usuarioValido.usuario
                };
            }
            return {
                success: false
            };
        }
        
        // Evento del formulario
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault(); // Evitar envío real
            
            var usuario = document.getElementById('usuario').value.trim();
            var password = document.getElementById('password').value.trim();
            
            // Validar campos vacíos
            if (!usuario || !password) {
                mostrarError('Por favor, completa todos los campos');
                return false;
            }
            
            // Mostrar loading
            var btn = document.querySelector('.btn-login');
            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Validando...';
            btn.disabled = true;
            
            // Simular validación (pequeño delay para efecto visual)
            setTimeout(function() {
                var resultado = validarLogin(usuario, password);
                
                if (resultado.success) {
                    // Credenciales correctas
                    guardarSesion(resultado.usuario, resultado.rol);
                    recordarUsuario(usuario);
                    
                    // Mostrar mensaje de éxito según el rol
                    if (resultado.rol === 'vendedor') {
                        btn.innerHTML = '<i class="bi bi-cart-plus"></i> Redirigiendo a ventas...';
                    } else if (resultado.rol === 'gerente') {
                        btn.innerHTML = '<i class="bi bi-box-seam"></i> Redirigiendo a productos...';
                    } else {
                        btn.innerHTML = '<i class="bi bi-house-door"></i> Redirigiendo al inicio...';
                    }
                    
                    // Redirigir según el rol del usuario
                    setTimeout(function() {
                        window.location.href = `@Url.Content("~/")${resultado.controller}/${resultado.action}`;
                    }, 500);
                } else {
                    // Credenciales incorrectas
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    mostrarError('Usuario o contraseña incorrectos');
                }
            }, 800);
        });
        
        // Cargar usuario recordado al iniciar
        document.addEventListener('DOMContentLoaded', function() {
            cargarUsuarioRecordado();
            
            // Agregar efecto de animación
            var card = document.querySelector('.login-card');
            card.style.opacity = '1';
        });
        
        // Permitir enviar con Enter
        document.getElementById('password').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('loginForm').dispatchEvent(new Event('submit'));
            }
        });
    </script>
</body>
</html>