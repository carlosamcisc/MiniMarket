@model MiniMarket.Models.Producto

@{
    ViewData["Title"] = "Detalles del Producto";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <!-- Tarjeta principal -->
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header con gradiente -->
                <div class="card-header bg-gradient-info text-white py-3" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-info-circle-fill fs-2 me-2"></i>
                            <div>
                                <h2 class="h4 mb-0 fw-bold">Detalles del Producto</h2>
                                <p class="mb-0 opacity-75 small">Información completa del producto</p>
                            </div>
                        </div>
                        <div class="badge bg-light text-dark px-3 py-2 rounded-pill">
                            <i class="bi bi-upc-scan me-1"></i> Código: @Model.Codigo
                        </div>
                    </div>
                </div>

                <!-- Cuerpo de detalles -->
                <div class="card-body p-4 p-lg-5">

                    <!-- Estado del producto (opcional según stock) -->
                    <div class="mb-4">
                        @{
                            int stock = ViewBag.Stock ?? 0;
                            string stockStatus = stock > 10 ? "success" : (stock > 0 ? "warning" : "danger");
                            string stockMessage = stock > 10 ? "Stock disponible" : (stock > 0 ? "Stock bajo" : "Sin stock");
                        }
                        <div class="alert alert-@stockStatus d-flex align-items-center rounded-3 shadow-sm" role="alert">
                            <i class="bi @(stock > 0 ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") fs-4 me-3"></i>
                            <div>
                                <strong>Estado del inventario:</strong> @stockMessage
                                <br><small>Stock actual: @stock unidades</small>
                            </div>
                        </div>
                    </div>

                    <!-- Tabla de detalles mejorada -->
                    <div class="table-responsive">
                        <table class="table table-hover table-borderless">
                            <tbody>
                                <!-- Nombre -->
                                <tr class="border-bottom">
                                    <td class="py-3" style="width: 35%; background-color: #f8f9fa; border-radius: 10px 0 0 10px;">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-primary bg-opacity-10 p-2 me-3">
                                                <i class="bi bi-tag text-primary fs-5"></i>
                                            </div>
                                            <strong class="text-secondary">@Html.DisplayNameFor(model => model.Nombre)</strong>
                                        </div>
                                    </td>
                                    <td class="py-3 fw-semibold">
                                        @Html.DisplayFor(model => model.Nombre)
                                    </td>
                                </tr>

                                <!-- Código -->
                                <tr class="border-bottom">
                                    <td class="py-3" style="background-color: #f8f9fa;">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-success bg-opacity-10 p-2 me-3">
                                                <i class="bi bi-upc-scan text-success fs-5"></i>
                                            </div>
                                            <strong class="text-secondary">@Html.DisplayNameFor(model => model.Codigo)</strong>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <code class="bg-light p-2 rounded">@Html.DisplayFor(model => model.Codigo)</code>
                                    </td>
                                </tr>

                                <!-- Precio -->
                                <tr class="border-bottom">
                                    <td class="py-3" style="background-color: #f8f9fa;">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-warning bg-opacity-10 p-2 me-3">
                                                <i class="bi bi-currency-dollar text-warning fs-5"></i>
                                            </div>
                                            <strong class="text-secondary">@Html.DisplayNameFor(model => model.Precio)</strong>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <span class="fs-4 fw-bold text-success">$ @Html.DisplayFor(model => model.Precio)</span>
                                        <small class="text-muted">MXN</small>
                                    </td>
                                </tr>

                                <!-- Stock -->
                                <tr>
                                    <td class="py-3" style="background-color: #f8f9fa; border-radius: 0 0 0 10px;">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-info bg-opacity-10 p-2 me-3">
                                                <i class="bi bi-box-seam text-info fs-5"></i>
                                            </div>
                                            <strong class="text-secondary">Stock actual</strong>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge @(stock > 0 ? "bg-success" : "bg-danger") px-3 py-2 rounded-pill">
                                                @stock unidades
                                            </span>
                                            @if (stock <= 5 && stock > 0)
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill">
                                                    <i class="bi bi-exclamation-triangle"></i> ¡Últimas unidades!
                                                </span>
                                            }
                                            else if (stock == 0)
                                            {
                                                <span class="badge bg-secondary rounded-pill">
                                                    <i class="bi bi-cart-x"></i> Agotado
                                                </span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Fecha de consulta -->
                    <div class="mt-4 pt-3 text-center text-muted border-top">
                        <small>
                            <i class="bi bi-clock-history me-1"></i>
                            Información actualizada al: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")
                        </small>
                    </div>

                    <!-- Botones de acción -->
                    <div class="d-flex gap-3 mt-4 pt-2">
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary flex-grow-1 btn-lg rounded-3 shadow-sm">
                            <i class="bi bi-pencil-square"></i> Editar producto
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-3">
                            <i class="bi bi-arrow-left"></i> Volver
                        </a>
                    </div>
                </div>
            </div>

            <!-- Tarjeta de acciones rápidas (opcional) -->
            <div class="row mt-4 g-3">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-body p-3 text-center">
                            <i class="bi bi-printer fs-4 text-secondary"></i>
                            <p class="mb-0 small text-muted mt-2">¿Necesitas imprimir?</p>
                            <button class="btn btn-sm btn-outline-secondary mt-2" onclick="window.print()">
                                <i class="bi bi-file-pdf"></i> Imprimir detalles
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-body p-3 text-center">
                            <i class="bi bi-share fs-4 text-secondary"></i>
                            <p class="mb-0 small text-muted mt-2">Acciones rápidas</p>
                            <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-sm btn-outline-danger mt-2">
                                <i class="bi bi-trash"></i> Eliminar producto
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Estilos adicionales -->
<style>
    /* Animación de entrada */
    .card {
        animation: slideDown 0.5s ease-out;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Hover en filas de la tabla */
    .table tbody tr {
        transition: all 0.2s ease;
    }

        .table tbody tr:hover {
            background-color: rgba(0, 0, 0, 0.02);
            transform: scale(1.01);
        }

    /* Botones mejorados */
    .btn-primary {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        border: none;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
        }

    .btn-outline-secondary:hover {
        transform: translateY(-2px);
    }

    /* Badges animados */
    .badge {
        transition: all 0.2s ease;
    }

    /* Código de barras simulado */
    code {
        font-family: 'Courier New', monospace;
        letter-spacing: 1px;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .card-body {
            padding: 1.5rem !important;
        }

        .btn-lg {
            font-size: 0.9rem;
            padding: 0.6rem 1rem;
        }

        .table tbody td {
            display: block;
            width: 100%;
        }

        .table tbody tr td:first-child {
            border-radius: 10px 10px 0 0;
        }
    }

    /* Mejora para impresión */
    @@media print {
        .btn, .alert, .row.mt-4, .card-footer, .badge {
            display: none;
        }

        .card {
            box-shadow: none;
            border: 1px solid #ddd;
        }

        body {
            padding: 0;
            margin: 0;
        }
    }
</style>

<!-- Script para funcionalidad adicional -->
<script>
    // Mostrar notificación al cargar la página (opcional)
    document.addEventListener('DOMContentLoaded', function() {
        console.log('Vista de detalles cargada - Producto: @Model.Nombre');
    });

    // Función para copiar el código del producto
    function copyCode() {
        const code = '@Model.Codigo';
        navigator.clipboard.writeText(code);

        // Mostrar tooltip o notificación
        const btn = event.target;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-check"></i> ¡Copiado!';
        setTimeout(() => {
            btn.innerHTML = originalText;
        }, 2000);
    }
</script>