@model MiniMarket.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <!-- Tarjeta principal de advertencia -->
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header con gradiente rojo (advertencia) -->
                <div class="card-header py-3" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-white bg-opacity-25 p-2 me-3">
                            <i class="bi bi-exclamation-triangle-fill text-white fs-2"></i>
                        </div>
                        <div>
                            <h2 class="h4 mb-0 fw-bold text-white">Eliminar Producto</h2>
                            <p class="mb-0 text-white opacity-75 small">Esta acción no se puede deshacer</p>
                        </div>
                    </div>
                </div>

                <!-- Cuerpo -->
                <div class="card-body p-4 p-lg-5">

                    <!-- Alerta de advertencia principal -->
                    <div class="alert alert-danger d-flex align-items-start rounded-3 shadow-sm mb-4" role="alert">
                        <i class="bi bi-shield-exclamation fs-1 me-3"></i>
                        <div>
                            <strong class="d-block fs-5">¿Estás seguro de que deseas eliminar este producto?</strong>
                            <p class="mb-0">Esta acción eliminará permanentemente el producto del sistema y no podrá ser recuperado.</p>
                        </div>
                    </div>

                    <!-- Información del producto a eliminar -->
                    <div class="mb-4">
                        <h5 class="fw-semibold mb-3">
                            <i class="bi bi-box-seam text-danger"></i> Producto a eliminar
                        </h5>

                        <div class="bg-light rounded-3 p-3">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary bg-opacity-10 p-2 me-2">
                                            <i class="bi bi-tag text-primary"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block">Nombre</small>
                                            <strong class="fs-6">@Html.DisplayFor(model => model.Nombre)</strong>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-success bg-opacity-10 p-2 me-2">
                                            <i class="bi bi-upc-scan text-success"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block">Código</small>
                                            <strong class="fs-6">@Html.DisplayFor(model => model.Codigo)</strong>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-warning bg-opacity-10 p-2 me-2">
                                            <i class="bi bi-currency-dollar text-warning"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block">Precio</small>
                                            <strong class="fs-5 text-success">$ @Html.DisplayFor(model => model.Precio)</strong>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-info bg-opacity-10 p-2 me-2">
                                            <i class="bi bi-box-seam text-info"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block">Stock actual</small>
                                            <strong class="fs-6">
                                                @{
                                                    int stock = ViewBag.Stock ?? 0;
                                                    if (stock == 0)
                                                    {
                                                        <span class="text-danger">@stock unidades (Agotado)</span>
                                                    }
                                                    else if (stock <= 5)
                                                    {
                                                        <span class="text-warning">@stock unidades (Stock bajo)</span>
                                                    }
                                                    else
                                                    {
                                                        <span>@stock unidades</span>
                                                    }
                                                }
                                            </strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Información adicional de seguridad -->
                    <div class="alert alert-warning rounded-3 mb-4">
                        <div class="d-flex">
                            <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                            <div>
                                <strong>Consecuencias de esta acción:</strong>
                                <ul class="mb-0 mt-2 small">
                                    <li>El producto será eliminado permanentemente</li>
                                    <li>No podrá ser recuperado en el futuro</li>
                                    <li>Los registros de ventas asociados podrían verse afectados</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Checkbox de confirmación -->
                    <div class="form-check mb-4 p-3 bg-light rounded-3">
                        <input class="form-check-input" type="checkbox" id="confirmDelete" style="cursor: pointer;">
                        <label class="form-check-label fw-semibold" for="confirmDelete" style="cursor: pointer;">
                            <i class="bi bi-check-circle"></i> Confirmo que deseo eliminar este producto permanentemente
                        </label>
                    </div>

                    <!-- Botones de acción -->
                    <form asp-action="Delete" id="deleteForm">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-3">
                            <button type="submit" id="deleteButton" class="btn btn-danger flex-grow-1 btn-lg rounded-3 shadow-sm" disabled>
                                <i class="bi bi-trash3"></i> Eliminar permanentemente
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-3">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tarjeta de información adicional -->
            <div class="card border-0 shadow-sm rounded-3 mt-4">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between flex-wrap">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-shield-check text-success fs-4 me-2"></i>
                            <span class="small text-muted">Operación segura con verificación de confirmación</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-clock-history text-muted me-1"></i>
                            <small class="text-muted">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Estilos adicionales -->
<style>
    /* Animación de entrada */
    .card {
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Botón eliminar */
    .btn-danger {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border: none;
        transition: all 0.3s ease;
    }

        .btn-danger:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(245, 87, 108, 0.4);
        }

        .btn-danger:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    /* Botón cancelar */
    .btn-outline-secondary:hover {
        transform: translateY(-2px);
    }

    /* Checkbox personalizado */
    .form-check-input:checked {
        background-color: #dc3545;
        border-color: #dc3545;
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
    }

    /* Efectos hover en las tarjetas */
    .bg-light {
        transition: all 0.2s ease;
    }

        .bg-light:hover {
            background-color: #e9ecef !important;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .card-body {
            padding: 1.5rem !important;
        }

        .btn-lg {
            font-size: 0.9rem;
            padding: 0.6rem 1rem;
        }

        .row.g-3 {
            gap: 1rem;
        }
    }

    /* Animación de vibración para advertencia */
    @@keyframes shake {
        0%, 100% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-5px);
        }

        75% {
            transform: translateX(5px);
        }
    }

    .alert-danger {
        animation: shake 0.5s ease-in-out;
    }
</style>

<!-- Script para habilitar/deshabilitar botón según confirmación -->
<script>
    // Referencias a elementos
    const confirmCheckbox = document.getElementById('confirmDelete');
    const deleteButton = document.getElementById('deleteButton');
    const deleteForm = document.getElementById('deleteForm');

    // Habilitar/deshabilitar botón según checkbox
    confirmCheckbox.addEventListener('change', function() {
        deleteButton.disabled = !this.checked;

        // Cambiar opacidad del botón visualmente
        if (this.checked) {
            deleteButton.style.opacity = '1';
        } else {
            deleteButton.style.opacity = '0.6';
        }
    });

    // Confirmación adicional al enviar el formulario
    deleteForm.addEventListener('submit', function(e) {
        if (!confirmCheckbox.checked) {
            e.preventDefault();
            alert('Por favor, confirma que deseas eliminar el producto marcando la casilla.');
            return false;
        }

        // Confirmación final con sweet alert o confirm nativo
        const userConfirmed = confirm('⚠️ ADVERTENCIA FINAL ⚠️\n\n¿Estás ABSOLUTAMENTE SEGURO de que deseas eliminar este producto?\n\nEsta acción es irreversible.');

        if (!userConfirmed) {
            e.preventDefault();
            return false;
        }

        // Mostrar mensaje de carga (opcional)
        deleteButton.innerHTML = '<i class="bi bi-hourglass-split"></i> Eliminando...';
        deleteButton.disabled = true;
    });

    // Prevenir envío accidental con teclas
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && deleteButton === document.activeElement) {
            e.preventDefault();
            if (!confirmCheckbox.checked) {
                alert('Debes confirmar la eliminación marcando la casilla primero.');
            } else {
                deleteForm.dispatchEvent(new Event('submit'));
            }
        }
    });
</script>
